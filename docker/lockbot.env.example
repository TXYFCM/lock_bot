# LockBot 生产环境配置示例 — 复制为 lockbot.env 后填入真实值
# cp lockbot.env.example lockbot.env && chmod 600 lockbot.env
# !!! lockbot.env 含密钥，权限设 600，切勿提交到 git、切勿发群 !!!

# ── 安全密钥（每个环境用独立的随机值）───────────────────────────
# JWT 签名密钥：泄露=别人可伪造任意管理员登录态
#   生成: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=__CHANGE_ME__请填入随机32字节hex

# 敏感字段加密密钥（加密 bot 的 token/webhook 等）
#   生成: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# !!! 一旦设定不要再改，否则已存的加密数据全部无法解密 !!!
ENCRYPTION_KEY=__CHANGE_ME__请填入Fernet密钥

# ── 行为开关 ─────────────────────────────────────────────────────
# 生产务必关掉 dev 自动建号
DEV_MODE=false
# 是否开放自助注册
ALLOW_REGISTER=false

# 数据库（默认 SQLite，落在挂载的 /data 卷里，无需改）
# DATABASE_URL=sqlite:////data/lockbot.db

# 时区
TZ=Asia/Shanghai
